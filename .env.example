# ================================
# Telegram Bot "Tebak Kata" Configuration
# ================================
# Copy this file to .env and configure your values

# ================================
# 🏗️ APPLICATION SETTINGS
# ================================
# Environment: development, staging, or production
ENVIRONMENT="" 				# Provide a value for ENVIRONMENT

# ================================
# 🤖 TELEGRAM BOT SETTINGS
# ================================
# Bot token from @BotFather (REQUIRED)
# Get it by messaging @BotFather on Telegram and creating a new bot
BOT_TOKEN="" 				# Provide a value for BOT_TOKEN

# Bot username (optional, for logging)
BOT_USERNAME="" 				# Provide a value for BOT_USERNAME


# ================================
# 🧠 LLM AGENT API SETTINGS (Optional)
# ================================
# LLM Agent API base URL
# Example: "https://agent.admasolusi.space"
LLM_URL="" 				# Provide a value for LLM_URL
LLM_MODEL_NAME="" 				# Provide a value for LLM_MODEL_NAME
LLM_API_KEY="" 				# Provide a value for LLM_API_KEY


# ================================
# 🗄️ DATABASE SETTINGS
# ================================
# Database URL (PostgreSQL with psycopg)
# Format: postgresql+psycopg://user:password@host:port/database
DATABASE_URL="" 				# Provide a value for DATABASE_URL

# For SQLite development (uncomment to use):
# DATABASE_URL="sqlite:///./tebak_kata.db"

# Enable database query logging (true/false)
DATABASE_ECHO="" 				# Provide a value for DATABASE_ECHO

# Database connection pool settings
DATABASE_POOL_SIZE="" 				# Provide a value for DATABASE_POOL_SIZE
DATABASE_MAX_OVERFLOW="" 				# Provide a value for DATABASE_MAX_OVERFLOW
TASK_DAILY_REMINDER_HOUR="" 				# Provide a value for TASK_DAILY_REMINDER_HOUR
TASK_DAILY_REMINDER_MINUTE="" 				# Provide a value for TASK_DAILY_REMINDER_MINUTE

# ================================
# 🚀 SERVER SETTINGS
# ================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL="" 				# Provide a value for LOG_LEVEL
